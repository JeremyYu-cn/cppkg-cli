{
  "name": "cppkg-cli",
  "version": "0.0.5",
  "description": "CLI for downloading C/C++ packages into a shared include directory or project workspace",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "bin": {
    "cppkg-cli": "./dist/main.js"
  },
  "files": [
    "dist",
    "README.md",
    "docs/README.zh-CN.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "dev": "node --import=tsx ./src/main.ts",
    "prepack": "npm run build",
    "test": "node -e \"process.stdout.write('No tests specified\\n')\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JeremyYu-cn/cppkg-cli.git"
  },
  "keywords": [
    "c++",
    "cli",
    "cpp",
    "header-only",
    "package",
    "management"
  ],
  "author": "Jeremy Yu",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/JeremyYu-cn/cppkg-cli/issues"
  },
  "homepage": "https://github.com/JeremyYu-cn/cppkg-cli#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "commander": "^14.0.3",
    "http-proxy-agent": "^9.0.0",
    "https-proxy-agent": "^9.0.0",
    "picocolors": "^1.1.1",
    "typescript": "^6.0.3",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/unzipper": "^0.10.11",
    "tsx": "^4.21.0"
  }
}
